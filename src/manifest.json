{
    "manifest_version": 3,
    "name": "Arxiver",
    "description": "Download research papers with their original title as the filename.",
    "version": "0.4",
    "action": {
        "default_icon": "icon-48.png",
        "default_title": "Arxiver"
    },
    "icons": {
        "16": "icon-16.png",
        "48": "icon-48.png"
    },
    "host_permissions": [
        "https://arxiv.org/*",
        "http://arxiv.org/*",
        "https://scholar.google.com/*",
        "https://mail.google.com/*"
    ],
    "permissions": ["activeTab", "scripting", "downloads"],
    "background": {
        "service_worker": "background.js"
    }
}
