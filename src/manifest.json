{
    "manifest_version": 3,
    "name": "Arxiver",
    "description": "Download arXiv papers with their original title as the filename.",
    "version": "0.3", 
    "action": {
        "default_icon": "icon-48.png",
        "default_title": "Arxiver"
    },
    "icons": {
        "16": "icon-16.png",
        "48": "icon-48.png"
    },
    "host_permissions": [
        "http://arxiv.org/*",
        "https://arxiv.org/*"
    ],
    "permissions": ["activeTab", "scripting"],  
    "background": {
        "service_worker": "background.js"
    },
    "web_accessible_resources": [
        {
            "resources": ["bookmarklet.js"],
            "matches": ["http://arxiv.org/*", "https://arxiv.org/*"]
        }
    ]
}
